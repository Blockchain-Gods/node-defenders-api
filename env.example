# App
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@host:5432/node_defenders

# Redis (Upstash)
REDIS_URL=rediss://...

# JWT
JWT_SECRET=        # openssl rand -hex 32
JWT_EXPIRES_IN=7d

# Internal (must match signer)
INTERNAL_API_KEY=

# Signer service
SIGNER_BASE_URL=http://localhost:3001

# Blockchain
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
FUJI_WSS_URL=wss://api.avax-test.network/ext/bc/C/ws

# Web3Auth
WEB3AUTH_JWKS_URL=https://api.openlogin.com/jwks

# Game constants
GAME_ID=1
SURVIVAL_MODE_ID=1